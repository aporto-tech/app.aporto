{
  "name": "@aporto-tech/sdk",
  "version": "0.5.9",
  "description": "The skill marketplace for AI agents. Discover thousands of capabilities by description, execute via smart provider routing, publish your own skills and earn — all through one API key.",
  "keywords": [
    "aporto",
    "ai",
    "sdk",
    "llm",
    "search",
    "agent"
  ],
  "homepage": "https://aporto.tech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aporto-tech/app.aporto.git",
    "directory": "packages/sdk"
  },
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "aporto": "bin/aporto"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
