datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  newApiUserId                  Int?
  stripeCustomerId              String?
  stripePaymentMethodId         String?
  stripePaymentMethodBrand      String?
  stripePaymentMethodLast4      String?
  stripePaymentMethodExpiry     String?
  lastInsufficientBalanceEmailAt DateTime?
  accounts                      Account[]
  sessions                      Session[]
  publisher                     Publisher?
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TopUpTransaction {
  id           String   @id @default(cuid())
  newApiUserId Int
  email        String
  orderId      String   @unique
  usdPaid      Float
  creditedUSD  Float
  quotaAdded   Int
  createdAt    DateTime @default(now())
}

model Rule {
  id             String    @id @default(cuid())
  newApiUserId   Int
  tokenId        Int
  tokenName      String
  type           String    // "total_limit" | "daily_limit" | "model_allowlist"
  limitUSD       Float?
  models         String?
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())
  alert80SentAt  DateTime?
  alert100SentAt DateTime?
  webhookUrl     String?
}

model PromoCode {
  id          String            @id @default(cuid())
  code        String            @unique
  creditUSD   Float
  maxUses     Int               @default(1)
  usedCount   Int               @default(0)
  createdAt   DateTime          @default(now())
  expiresAt   DateTime?
  redemptions PromoRedemption[]
}

model PromoRedemption {
  id          String    @id @default(cuid())
  promoCodeId String
  userId      String
  redeemedAt  DateTime  @default(now())
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])

  @@unique([promoCodeId, userId])
}

model ServiceUsage {
  id           String   @id @default(cuid())
  newApiUserId Int
  service      String   // "sms" | "search" | "ai-search" | "tts" | "image"
  provider     String   // "prelude" | "linkup" | "youcom" | "elevenlabs" | "fal"
  costUSD      Float
  metadata     String?  // JSON: request params + response metadata
  createdAt    DateTime @default(now())

  @@index([newApiUserId])
  @@index([service])
}

model Publisher {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  displayName     String
  website         String?
  description     String?
  status          String    @default("pending")  // "pending" | "approved" | "suspended"
  approvedAt      DateTime?
  approvedBy      String?   // admin email
  revenueShare    Float     @default(0.85)
  stripeAccountId String?
  createdAt       DateTime  @default(now())
  skills          Skill[]
  apiKeys         PublisherApiKey[]
  revenue         SkillRevenue[]

  @@index([status])
}

model PublisherApiKey {
  id          String    @id @default(cuid())
  publisherId String
  publisher   Publisher @relation(fields: [publisherId], references: [id])
  name        String
  lookupHash  String    @unique  // sha256(key) — fast indexed lookup
  keyHmac     String             // hmac-sha256(key, PUBLISHER_KEY_HMAC_SECRET) — anti-rainbow
  prefix      String             // first 8 chars shown in UI: "sk-pub-ab12..."
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([publisherId])
}

model Skill {
  id           Int        @id @default(autoincrement())
  name         String
  description  String
  embedding    Unsupported("vector(1536)")?
  paramsSchema String?    // JSON: {field: type} for execute_skill params
  tags         String?    // JSON array for display/filtering
  category     String?    // e.g. "media/image", "search/web", "llm/chat"
  capabilities String?    // JSON array: ["generate", "search", ...]
  inputTypes   String?    // JSON array: ["text", "image", "audio", "url", "json"]
  outputTypes  String?    // JSON array: ["text", "image", "audio", "url", "json", "binary"]
  isActive     Boolean    @default(true)
  publisherId  String?    // null = Aporto internal; FK to Publisher
  publisher    Publisher? @relation(fields: [publisherId], references: [id])
  status       String     @default("live")  // "draft" | "pending_review" | "live" | "rejected"
  reviewNote   String?    // admin note on rejection
  lastEditedAt DateTime?  // for resubmit guard: must be > rejectedAt
  inputSchema  String?    // JSON Schema (MCP compatibility)
  mcpVersion   String?    // MCP protocol version
  createdAt    DateTime   @default(now())
  providers    Provider[]
  calls        SkillCall[]
  revenue      SkillRevenue[]

  @@index([status])
  @@index([publisherId])
}

model Provider {
  id           Int        @id @default(autoincrement())
  skillId      Int
  skill        Skill      @relation(fields: [skillId], references: [id])
  name         String
  endpoint     String
  pricePerCall Float
  costPerChar  Float?     // if set, cost = costPerChar * params.text.length (overrides pricePerCall)
  avgLatencyMs Int        @default(500)
  retryRate    Float      @default(0)
  timeoutRate     Float      @default(0)
  providerSecret  String?
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  calls           SkillCall[]
}

model SkillCall {
  id             Int      @id @default(autoincrement())
  sessionId      String
  newApiUserId   Int
  skillId        Int
  providerId     Int
  isRetry        Boolean  @default(false)
  latencyMs      Int?
  success        Boolean?
  costUSD        Float?
  paramsHash     String?
  errorType      String?
  createdAt      DateTime @default(now())

  skill          Skill    @relation(fields: [skillId], references: [id])
  provider       Provider @relation(fields: [providerId], references: [id])
  skillRevenue   SkillRevenue?

  @@index([sessionId, newApiUserId, skillId, createdAt])
  @@index([newApiUserId])
  @@index([newApiUserId, paramsHash, createdAt])
  @@index([createdAt(sort: Desc)])
}

model SkillRevenue {
  id                  String    @id @default(cuid())
  skillId             Int
  skill               Skill     @relation(fields: [skillId], references: [id])
  publisherId         String
  publisher           Publisher @relation(fields: [publisherId], references: [id])
  skillCallId         Int       @unique
  skillCall           SkillCall @relation(fields: [skillCallId], references: [id])
  grossUSD            Float
  revenueShare        Float
  publisherEarningUSD Float
  paidOut             Boolean   @default(false)
  paidOutAt           DateTime?
  createdAt           DateTime  @default(now())

  @@index([publisherId, paidOut])
  @@index([publisherId, createdAt(sort: Desc)])
}

model PublisherWaitlist {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  useCase   String?
  createdAt DateTime @default(now())
  approved  Boolean  @default(false)
}
