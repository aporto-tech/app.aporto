datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  newApiUserId                  Int?
  stripeCustomerId              String?
  stripePaymentMethodId         String?
  stripePaymentMethodBrand      String?
  stripePaymentMethodLast4      String?
  stripePaymentMethodExpiry     String?
  lastInsufficientBalanceEmailAt DateTime?
  accounts                      Account[]
  sessions                      Session[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TopUpTransaction {
  id           String   @id @default(cuid())
  newApiUserId Int
  email        String
  orderId      String   @unique
  usdPaid      Float
  creditedUSD  Float
  quotaAdded   Int
  createdAt    DateTime @default(now())
}

model Rule {
  id             String    @id @default(cuid())
  newApiUserId   Int
  tokenId        Int
  tokenName      String
  type           String    // "total_limit" | "daily_limit" | "model_allowlist"
  limitUSD       Float?
  models         String?
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())
  alert80SentAt  DateTime?
  alert100SentAt DateTime?
  webhookUrl     String?
}

model PromoCode {
  id          String            @id @default(cuid())
  code        String            @unique
  creditUSD   Float
  maxUses     Int               @default(1)
  usedCount   Int               @default(0)
  createdAt   DateTime          @default(now())
  expiresAt   DateTime?
  redemptions PromoRedemption[]
}

model PromoRedemption {
  id          String    @id @default(cuid())
  promoCodeId String
  userId      String
  redeemedAt  DateTime  @default(now())
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])

  @@unique([promoCodeId, userId])
}

model ServiceUsage {
  id           String   @id @default(cuid())
  newApiUserId Int
  service      String   // "sms" | "search" | "ai-search" | "tts" | "image"
  provider     String   // "prelude" | "linkup" | "youcom" | "elevenlabs" | "fal"
  costUSD      Float
  metadata     String?  // JSON: request params + response metadata
  createdAt    DateTime @default(now())

  @@index([newApiUserId])
  @@index([service])
}
