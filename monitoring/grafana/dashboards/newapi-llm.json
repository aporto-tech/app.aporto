      "title": "📅 Расходы по месяцам / итого за год",
      "type": "table",
      "targets": [
        {
          "rawSql": "SELECT period AS \"Период\", total_usd AS \"Расходы ($)\", request_count AS \"Запросов\"\nFROM (\n  SELECT\n    TO_CHAR(DATE_TRUNC('month', day), 'YYYY-MM') AS period,\n    ROUND(SUM(total_usd)::numeric, 4)            AS total_usd,\n    SUM(request_count)::bigint                   AS request_count,\n    TO_CHAR(DATE_TRUNC('month', day), 'YYYY-MM') AS sort_key\n  FROM daily_spending_cache\n  GROUP BY DATE_TRUNC('month', day)\n\n  UNION ALL\n\n  SELECT\n    EXTRACT(YEAR FROM day)::text || ' — ИТОГО'  AS period,\n    ROUND(SUM(total_usd)::numeric, 4)            AS total_usd,\n    SUM(request_count)::bigint                   AS request_count,\n    EXTRACT(YEAR FROM day)::text || '-99'        AS sort_key\n  FROM daily_spending_cache\n  GROUP BY EXTRACT(YEAR FROM day)\n) t\nORDER BY sort_key;",
          "format": "table",
          "refId": "A"
        }
