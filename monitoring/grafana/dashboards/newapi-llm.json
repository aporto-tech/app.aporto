        {
          "rawSql": "SELECT c.name AS \"Канал\", CASE c.status WHEN 1 THEN '🟢 Active' WHEN 2 THEN '🔴 Disabled' ELSE '⚪ Unknown' END AS \"Статус\", c.priority AS \"Приоритет\", c.weight AS \"Вес\", c.response_time AS \"Response Time (мс)\", c.models AS \"Модели\", COALESCE(l.req_count, 0) AS \"Запросов (24ч)\", COALESCE(l.err_count, 0) AS \"Ошибок (24ч)\" FROM channels c LEFT JOIN (SELECT channel_id, count(*) AS req_count, count(*) FILTER (WHERE type != 2) AS err_count FROM logs WHERE created_at > extract(epoch from now() - interval '24 hours') GROUP BY channel_id) l ON c.id = l.channel_id ORDER BY c.status, c.priority DESC;",
